  "keyFeatures": [
    "Single-call animation playback with priority, speed, weight, and fade control",
    "Animation queue system for sequential playback",
    "Cross-fade transitions between animations",
    "Pause and resume with preserved time position",
    "Per-model and per-group animation tracking",
    "Layer system (FullBody, UpperBody, LowerBody, Face)",
    "State machine helpers for model state tracking",
    "Physics ragdoll with automatic restore",
    "Animation marker event callbacks",
    "Automatic model cleanup on Destroying"
  ],
  "publicApiSurface": [
    "EZAnim.init(Options)",
    "EZAnim:play(Model, Id, Priority?, Looped?, Fade?, Speed?, Weight?, Layer?, Group?)",
    "EZAnim:playOnce(...)",
    "EZAnim:stop(Model, Id, FadeTime?)",
    "EZAnim:stopAll(Model, FadeTime?)",
    "EZAnim:pause(Model, Id)",
    "EZAnim:resume(Model, Id)",
    "EZAnim:crossFade(Model, From, To, FadeTime?)",
    "EZAnim:queue(Model, AnimationList, Fade?, Speed?, Weight?)",
    "EZAnim:setState(Model, State)",
    "EZAnim:getState(Model)",
    "EZAnim:setSpeed(Model, Id, Speed)",
    "EZAnim:setWeight(Model, Id, Weight, Fade?)",
    "EZAnim:setTime(Model, Id, TimePosition)",
    "EZAnim:preload(Ids)",
    "EZAnim:onStopped(Model, Id, Callback)",
    "EZAnim:onEnded(Model, Id, Callback)",
    "EZAnim:onMarker(Model, Id, Marker, Callback)",
    "EZAnim:ragdoll(Model, Duration?)",
    "EZAnim:unragdoll(Model)",
    "EZAnim:tween(Model, Id, TargetSpeed?, TargetWeight?, Time?)"
  ]
